---
import CompetencePreview from "@components/competences/Competence_preview.astro";
import { competencesPreviewList } from "@/data/competences";

interface Props {
  competencesType: "hard" | "soft";
}

const { competencesType } = Astro.props;
---

<div class="mt-12 space-y-12" role="list">
  {
    competencesPreviewList.filter((competence) => competence.displayable && competence.type === competencesType).map((competence) => (
      <CompetencePreview
        id={competence.id}
        title={competence.title}
        description={competence.description}
        imageSrc={competence.imageSrc}
        link={competence.localLink}
      />
    ))
  }
</div>
