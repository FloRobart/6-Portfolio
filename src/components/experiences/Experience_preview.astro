---
import type { ImageMetadata } from "astro";
import { Picture } from "astro:assets";
import Button from "@components/Button.astro";

interface Props {
  id: string;
  title: string;
  description: string;
  imageSrc: ImageMetadata;
  link: string;
}

const { id, title, description, imageSrc, link } = Astro.props;
---

<div
  class="competences__row"
  id={id}
  role="article"
  aria-labelledby={id + "-title"}
>
  <div class="competences__row-img-cont">
    <Picture
      src={imageSrc}
      alt={title}
      width={imageSrc.width/2}
      height={imageSrc.height/2}
      loading="lazy"
      decoding="async"
      class="competences__row-img"
    />
  </div>
  <div class="competences__row-content">
    <h3
      class="competences__row-content-title"
      id={id + "-title"}
    >
      {title}
    </h3>
    <p
      class="competences__row-content-desc"
      set:html={description}
    />
    <Button
      href={link}
      text="En savoir plus"
    />
  </div>
</div>

<style>
  .competences__row {
    display: grid;
    grid-template-columns: minmax(0, 1.3fr) minmax(0, 1fr);
    gap: 2rem;
    margin-bottom: 3rem;
    align-items: center;
  }

  .competences__row:last-child {
    margin-bottom: 0;
  }

  .competences__row-img-cont {
    overflow: hidden;
    /* border: 1px solid var(--color-black); */
    border-radius: 12px;
    justify-self: end;
    max-width: min(100%, 420px);
    width: 100%;
    align-self: center;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .competences__row-img {
    width: auto;
    height: auto;
    max-width: 100%;
    max-height: 220px;
    object-fit: contain;
    display: block;
  }

  .competences__row-content {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.9rem;
  }

  .competences__row-content-title {
    font-weight: 700;
    font-size: 1.45rem;
    line-height: 1.2;
    margin: 0;
  }

  .competences__row-content-desc {
    font-size: 0.92rem;
    color: #555;
    line-height: 1.55;
    margin: 0;
  }

  .competences__row-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.55rem 1rem;
    border: 1px solid var(--color-black);
    border-radius: 999px;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-black);
    text-decoration: none;
    transition:
      background-color 0.2s ease,
      color 0.2s ease;
  }

  .competences__row-link:hover {
    background: var(--color-black);
    color: var(--color-white);
  }

  @media (max-width: 900px) {
    .competences__row {
      grid-template-columns: 1fr;
      gap: 1rem;
      text-align: center;
    }

    .competences__row-img-cont {
      justify-self: center;
    }

    .competences__row-content {
      align-items: center;
    }

    .competences__row-content-title {
      font-size: 1.3rem;
    }

    .competences__row-content-desc {
      font-size: 0.88rem;
    }

    .competences__row-img {
      max-height: 220px;
    }
  }
</style>
