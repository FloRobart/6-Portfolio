---
import { getExperienceById } from "@/data/experiences";
import { getProjectById } from "@/data/projects";

const experienceLocalLinks = {
  qowisio: getExperienceById("qowisio")?.localLink || "https://www.qowisio.com/",
  lalachante: getExperienceById("lalachante")?.localLink || "https://www.lalachante.com/",
  iscod: getExperienceById("iscod")?.localLink || "https://www.iscod.fr/formation-ingenierie-avancee-du-logiciel-en-alternance",
  iut_le_havre: getExperienceById("iut-le-havre")?.localLink || "https://www-iut.univ-lehavre.fr/info",
  lycee_sadi_carnot: getExperienceById("lycee-sadi-carnot")?.localLink || "https://lyc-bertin-carnot.paysdelaloire.e-lyco.fr/",
  lycee_duplessis: getExperienceById("lycee-duplessis")?.localLink || "https://duplessis-mornay.paysdelaloire.e-lyco.fr/",
};

const projectLocalLinks = {
  floraccess: getProjectLink("floraccess"),
  flower_garden: getProjectLink("flower-garden"),
  flollylist: getProjectLink("flollylist"),
  econoris: getProjectLink("econoris"),
  lyssecure: getProjectLink("lyssecure"),
  documentation: getProjectLink("documentation"),
  maven_lite: getProjectLink("maven-lite"),
  alloscp: getProjectLink("alloscp"),
  theme_vscode: getProjectLink("theme-vscode"),
};

function getProjectLink(projectId: string): string {
  const project = getProjectById(projectId);
  if (!project) {
    return "#";
  }

  if (!project.displayable) {
    return project.githubLink || "#";
  }

  return project?.localLink || project?.githubLink || "#";
}
---

<script define:vars={{ experienceLocalLinks, projectLocalLinks }}>
  window.__experienceLocalLinks = experienceLocalLinks;
  window.__projectLocalLinks = projectLocalLinks;
</script>

<script type="module">
  const experienceLocalLinks = window.__experienceLocalLinks || {};
  const projectLocalLinks = window.__projectLocalLinks || {};

  /**
   * Initialise Mermaid pour le rendu des diagrammes de parcours.
   * Configure les options de thème et de timeline pour une meilleure lisibilité.
   */
  import mermaid from "https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs";
  mermaid.initialize({
    startOnLoad: false,
    logLevel: "error",
    theme: "neutral",
    timeline: {
      disableMulticolor: true,
    },
    themeVariables: {
      cScale0: "#721414",
      cScaleLabel0: "#ffffff",
      cScale1: "#721414",
      cScaleLabel1: "#ffffff",
      cScale2: "#721414",
      cScaleLabel2: "#ffffff",
      cScale3: "#721414",
      cScaleLabel3: "#ffffff",
    },
  });

  /**
   * Rend Mermaid et enrichit les nœuds après le rendu.
   * Compatible avec la navigation Astro (ClientRouter).
   */
  async function renderMermaidTimeline() {
    const timeline = document.querySelector("pre.mermaid");
    if (!timeline) {
      return;
    }

    if (!timeline.hasAttribute("data-current-month-applied")) {
      const currentMonth = new Date().toLocaleString("fr-FR", {
        month: "long",
      });
      const capitalizedMonth = currentMonth.charAt(0).toUpperCase() + currentMonth.slice(1);

      timeline.textContent = timeline.textContent.replace("__CURRENT_MONTH__", capitalizedMonth);
      timeline.setAttribute("data-current-month-applied", "true");
    }

    await mermaid.run({ querySelector: ".mermaid" });

    const nodes = document.querySelectorAll(".mermaid svg text");
    nodes.forEach((node) => {
      /*----------------------*/
      /* Obtention de diplome */
      /*----------------------*/
      if (node.textContent.toUpperCase().includes("Obtention".toUpperCase()) && node.textContent.toUpperCase().includes("du".toUpperCase())) {
        addBoldToNode(node);

        if (node.textContent.toUpperCase().includes("BUT".toUpperCase())) {
          addLinkToNode(node, "https://fr.wikipedia.org/wiki/Bachelor_universitaire_de_technologie");
        }

        if (node.textContent.toUpperCase().includes("DUT".toUpperCase())) {
          addLinkToNode(node, "https://fr.wikipedia.org/wiki/Dipl%C3%B4me_universitaire_de_technologie");
        }

        if (node.textContent.toUpperCase().includes("BAC".toUpperCase())) {
          addLinkToNode(
            node,
            "https://fr.wikipedia.org/wiki/Baccalaur%C3%A9at_sciences_et_technologies_de_l%27industrie_et_du_d%C3%A9veloppement_durable",
          );
        }
      }

      /*------------*/
      /* Entreprise */
      /*------------*/
      /* Qowisio */
      if (node.textContent.toUpperCase().includes("QOWISIO".toUpperCase())) {
        addLinkToNode(node, experienceLocalLinks.qowisio);
        addBoldToNode(node);
      }

      /* LalaChante */
      if (node.textContent.toUpperCase().includes("LALACHANTE".toUpperCase())) {
        addLinkToNode(node, experienceLocalLinks.lalachante);
        addBoldToNode(node);
      }

      /*-------*/
      /* Ecole */
      /*-------*/
      /* ISCOD */
      if (node.textContent.toUpperCase().includes("ISCOD".toUpperCase())) {
        addLinkToNode(node, experienceLocalLinks.iscod);
        addBoldToNode(node);
      }

      /* IUT du Havre */
      if (node.textContent.toUpperCase().includes("IUT".toUpperCase())) {
        addLinkToNode(node, experienceLocalLinks.iut_le_havre);
        addBoldToNode(node);
      }

      /* SADI Carnot */
      if (node.textContent.toUpperCase().includes("SADI".toUpperCase()) && node.textContent.toUpperCase().includes("CARNOT".toUpperCase())) {
        addLinkToNode(node, experienceLocalLinks.lycee_sadi_carnot);
        addBoldToNode(node);
      }

      /* Duplessis Mornay */
      if (node.textContent.toUpperCase().includes("Duplessis".toUpperCase()) && node.textContent.toUpperCase().includes("Mornay".toUpperCase())) {
        addLinkToNode(node, experienceLocalLinks.lycee_duplessis);
        addBoldToNode(node);
      }

      /*---------*/
      /* Projets */
      /*---------*/
      /* FlorAccess */
      if (node.textContent.toUpperCase().includes("FlorAccess".toUpperCase())) {
        addLinkToNode(node, projectLocalLinks.floraccess);
      }

      /* Flower garden */
      if (node.textContent.toUpperCase().includes("Flower".toUpperCase()) && node.textContent.toUpperCase().includes("garden".toUpperCase())) {
        addLinkToNode(node, projectLocalLinks.flower_garden);
      }

      /* FlollyList */
      if (node.textContent.toUpperCase().includes("FlollyList".toUpperCase())) {
        addLinkToNode(node, projectLocalLinks.flollylist);
      }

      /* Econoris */
      if (node.textContent.toUpperCase().includes("Econoris".toUpperCase())) {
        addLinkToNode(node, projectLocalLinks.econoris);
      }

      /* Lyssecure */
      if (node.textContent.toUpperCase().includes("LysSecure".toUpperCase())) {
        addLinkToNode(node, projectLocalLinks.lyssecure);
      }

      /* Documentation */
      if (node.textContent.toUpperCase().includes("Documentation".toUpperCase())) {
        addLinkToNode(node, projectLocalLinks.documentation);
      }

      /* Maven Lite */
      if (node.textContent.toUpperCase().includes("Maven".toUpperCase()) && node.textContent.toUpperCase().includes("Lite".toUpperCase())) {
        addLinkToNode(node, projectLocalLinks.maven_lite);
      }

      /* All'OScp */
      if (node.textContent.toUpperCase().includes("All'OScp".toUpperCase())) {
        addLinkToNode(node, projectLocalLinks.alloscp);
      }

      /* Thème pour Visual Studio Code */
      if (node.textContent.toUpperCase().includes("thème".toUpperCase()) && node.textContent.toUpperCase().includes("Code".toUpperCase())) {
        addLinkToNode(node, projectLocalLinks.theme_vscode);
      }
    });
  }

  if (!window.__mermaidTimelineInitBound) {
    window.__mermaidTimelineInitBound = true;
    document.addEventListener("astro:page-load", renderMermaidTimeline);
    document.addEventListener("DOMContentLoaded", renderMermaidTimeline);
  }

  renderMermaidTimeline();

  /**
   * Ajoute un lien cliquable à un nœud SVG.
   * @param {Element} node - Le nœud SVG auquel ajouter le lien.
   * @param {string} url - L'URL vers laquelle le lien doit pointer.
   */
  function addLinkToNode(node, url) {
    if (!url || url === "#") {
      return;
    }

    const group = node.closest("g");
    if (!group || !group.parentNode) {
      return;
    }

    if (group.closest("a")) {
      return;
    }

    const link = document.createElementNS("http://www.w3.org/2000/svg", "a");
    link.setAttribute("href", url);
    link.setAttribute("class", "parcours-link");

    group.parentNode.insertBefore(link, group);
    link.appendChild(group);
  }

  /**
   * Ajoute un style de texte en gras à un nœud SVG.
   * @param node - Le nœud SVG auquel ajouter le style en gras.
   */
  function addBoldToNode(node) {
    const group = node.closest("g");
    if (!group) {
      return;
    }

    const text = group.querySelector("text");
    if (text) {
      text.setAttribute("font-weight", "bold");
    }
  }
</script>
