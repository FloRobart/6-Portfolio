---
import { Image } from "astro:assets";

const profile = {
  firstName: "Floris",
  lastName: "Robart",
};

import profileImage from "@assets/profile_picture.jpg";

const navItems = [
  { label: "Accueil", href: "/" },
  { label: "Parcours", href: "/parcours" },
  { label: "Réalisations", href: "/projets" },
  { label: "Compétences", href: "/competences" },
  { label: "Contact", href: "/contact" },
];

const currentPath = Astro.url.pathname;
---

<style>
  .mobile-menu-panel {
    transform-origin: top right;
    transition: opacity 0.2s ease, transform 0.2s ease;
  }

  details:not([open]) .mobile-menu-panel {
    opacity: 0;
    transform: scale(0.97) translateY(-6px);
    pointer-events: none;
  }

  details[open] .mobile-menu-panel {
    opacity: 1;
    transform: scale(1) translateY(0);
  }

  .burger-line {
    transform-origin: center;
    transition: transform 0.2s ease, opacity 0.2s ease;
  }

  details[open] .burger-line--top {
    transform: translateY(6px) rotate(45deg);
  }

  details[open] .burger-line--middle {
    opacity: 0;
  }

  details[open] .burger-line--bottom {
    transform: translateY(-6px) rotate(-45deg);
  }

  summary::-webkit-details-marker {
    display: none;
  }
</style>

<header
  class="sticky top-0 z-50 border-b border-[var(--color-background-dark)] bg-[color:color-mix(in_srgb,var(--color-white)_90%,transparent)] backdrop-blur"
>
  <div class="mx-auto flex w-full items-center justify-between gap-3 px-4 py-3">
    <a
      class="inline-flex items-center gap-3 text-[var(--color-text)] no-underline transition hover:text-[var(--color-primary)]"
      href="/"
    >
      <!-- Profile image -->
      <Image
        src={profileImage}
        alt="Profile"
        width={80}
        height={80}
        loading="eager"
        decoding="async"
        class="h-10 w-10 rounded-full object-cover"
      />

      <!-- Profile name -->
      <span class="text-base font-bold tracking-tight">
        {profile.firstName}
        {profile.lastName}
      </span>
    </a>

    <!-- Desktop navigation (> 700px) -->
    <nav aria-label="Navigation principale" class="max-[700px]:hidden">
      <ul class="m-0 flex list-none flex-wrap items-center gap-1 p-0">
        {
          navItems.map((item) => (
            <li>
              <a
                href={item.href}
                class:list={[
                  "ui-nav-link",
                  currentPath === item.href && "ui-nav-link--active",
                ]}
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <!-- Mobile navigation (<= 700px) -->
    <details class="relative hidden max-[700px]:block">
      <summary
        class="flex h-10 w-10 cursor-pointer list-none items-center justify-center rounded-md border border-[var(--color-background-dark)] text-[var(--color-text)] transition hover:bg-[var(--color-background-light)] hover:text-[var(--color-primary)]"
        aria-label="Ouvrir le menu"
      >
        <span class="relative block h-4 w-5" aria-hidden="true">
          <span class="burger-line burger-line--top absolute left-0 top-0 h-0.5 w-5 rounded-full bg-current"></span>
          <span class="burger-line burger-line--middle absolute left-0 top-[7px] h-0.5 w-5 rounded-full bg-current"></span>
          <span class="burger-line burger-line--bottom absolute left-0 top-[14px] h-0.5 w-5 rounded-full bg-current"></span>
        </span>
      </summary>

      <nav
        aria-label="Navigation mobile"
        class="mobile-menu-panel absolute right-0 mt-2 w-52 rounded-lg border border-[var(--color-background-dark)] bg-[var(--color-white)] p-1 shadow-lg"
      >
        <ul class="m-0 list-none p-0">
          {
            navItems.map((item) => (
              <li>
                <a
                  href={item.href}
                  class:list={[
                    "ui-nav-link flex w-full",
                    currentPath === item.href && "ui-nav-link--active",
                  ]}
                >
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>
    </details>
  </div>
</header>
