---
import CompetenceDetailHeader from "@/components/competences/Competence_detail_header.astro";
import IngeniositeContent from "@/components/competences/contents/ingeniosite_content.astro";
import MainLayout from "@layouts/MainLayout.astro";
import { getCompetenceById } from "@/data/competences";
import SocialLink from "@/components/Social_link.astro";

const competence = getCompetenceById("ingeniosite");

if (!competence) {
  throw new Error("Competence 'ingeniosite' not found in competences data.");
}
---

<MainLayout>
  <CompetenceDetailHeader
    id={competence.id}
    title={competence.title}
    description={competence.description}
  />

  <SocialLink />

  <div class="max-w-7xl mx-auto mb-24">
    <IngeniositeContent />
  </div>
</MainLayout>
