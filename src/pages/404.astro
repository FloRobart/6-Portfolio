---
import MainLayout from "@layouts/MainLayout.astro";
---

<MainLayout>
  <div class="flex min-h-[60vh] items-center justify-center px-6 py-10 bg-[var(--color-background-light)]">
    <section class="mx-auto flex w-full max-w-2xl flex-col items-center rounded-3xl border border-[var(--color-background-dark)] bg-[var(--color-white)] px-6 py-10 text-center shadow-sm sm:px-8">
      <h1 class="text-3xl font-bold tracking-tight text-[var(--color-primary-dark)] sm:text-4xl">404 - Not Found</h1>
      <p class="mt-4 text-base leading-relaxed text-[var(--color-text)] sm:text-lg">Désolé, la page que vous recherchez n'existe pas.</p>
    </section>
  </div>
</MainLayout>