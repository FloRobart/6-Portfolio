---
import ExperienceDetailHeader from "@/components/experiences/Experience_detail_header.astro";
import IscodContent from "@/components/experiences/contents/iscod_content.astro";
import MainLayout from "@layouts/MainLayout.astro";
import { getExperienceById } from "@/data/experiences";
import SocialLink from "@/components/Social_link.astro";

const experience = getExperienceById("iscod");

if (!experience) {
  throw new Error("Experience 'iscod' not found in experiences data.");
}
---

<MainLayout>
  <ExperienceDetailHeader
    id={experience.id}
    title={experience.title}
    description={experience.description}
    buttonLink={experience.externalLink}
    buttonText={"Voir le site de " + experience.title}
  />

  <SocialLink />

  <div class="max-w-7xl mx-auto mb-24">
    <IscodContent image={experience.imageSrc} />
  </div>
</MainLayout>
