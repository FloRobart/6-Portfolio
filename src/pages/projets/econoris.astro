---
import ProjetDetail from "@/components/projets/Projet_detail_header.astro";
import MainLayout from "@layouts/MainLayout.astro";
import { getProjectById } from "@/data/projects";

const project = getProjectById("econoris");

if (!project) {
  throw new Error("Project 'econoris' not found in projects data.");
}
---

<MainLayout>
  <ProjetDetail
    id={project.id}
    title={project.title}
    description={project.description}
    githubButtonText="Voir le projet sur Github"
    githubButtonLink={project.githubLink}
    externalButtonText="Voir le projet en ligne"
    externalButtonLink={project.projectLink}
  >
    <Fragment slot="content">
      <p>Test</p>
    </Fragment>
  </ProjetDetail>
</MainLayout>
